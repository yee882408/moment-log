# 下面兩個是「公開值」（publishable / anon key）：會出現在前端，安全靠 RLS，非機密
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 忘記密碼寄信時組 redirectTo 網址用；本機開發用 localhost，正式環境要換成實際部署網域
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 機密！繞過 RLS，只能放後端、絕不進 git。設 admin role 等後端操作才會用到
# SUPABASE_SECRET_KEY=sb_secret_xxx

# Cloudflare Turnstile（登入/註冊人機驗證）：到 Cloudflare Dashboard 建立 widget 取得
# https://dash.cloudflare.com/?to=/:account/turnstile
# site key 是公開值（前端 widget 用），secret key 是機密（只能後端用，絕不進 git）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
